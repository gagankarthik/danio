{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "jsxImportSource": "danio-js",
    "paths": {
      "danio-js": ["./types/index.d.ts"],
      "danio-js/jsx-runtime": ["./types/jsx-runtime.d.ts"],
      "danio-js/jsx-dev-runtime": ["./types/jsx-runtime.d.ts"]
    }
  },
  "include": ["types/**/*.ts", "test/types.test-d.tsx"]
}
